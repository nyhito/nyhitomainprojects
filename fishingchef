local function saveUserPreferences()
	if not writefile then return end
	local payload = {
		afkFishTime = tonumber(afkFishTime) or 5,
		afkFishPositionStr = tostring(afkFishPositionStr),
		autoMegEnabled = autoMegEnabled,
		autoKoiEnabled = autoKoiEnabled,
		autoMmtEnabled = autoMmtEnabled
	}
	pcall(function()
		writefile(PREFS_FILE, HttpService:JSONEncode(payload))
	end)
end

local function loadUserPreferences()
	if not readfile or not isfile or not isfile(PREFS_FILE) then return end
	pcall(function()
		local raw = readfile(PREFS_FILE)
		local decoded = HttpService:JSONDecode(raw)
		if tonumber(decoded.afkFishTime) then
			afkFishTime = math.clamp(math.floor(tonumber(decoded.afkFishTime)), 1, 60)
		end
		if type(decoded.afkFishPositionStr) == "string" then
			afkFishPositionStr = decoded.afkFishPositionStr
			local x, y, z = afkFishPositionStr:match("([^,]+),([^,]+),([^,]+)")
			if x and y and z then
				afkFishDestino = CFrame.new(tonumber(x), tonumber(y), tonumber(z))
			end
		end
		if type(decoded.autoMegEnabled) == "boolean" then autoMegEnabled = decoded.autoMegEnabled end
		if type(decoded.autoKoiEnabled) == "boolean" then autoKoiEnabled = decoded.autoKoiEnabled end
		if type(decoded.autoMmtEnabled) == "boolean" then autoMmtEnabled = decoded.autoMmtEnabled end
	end)
end

