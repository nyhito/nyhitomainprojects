-- LÓGICA DO AFK FISH (LOOP)
-- ==========================================
local function clicar(x, y)
	VIM:SendMouseMoveEvent(x, y, game)
	task.wait(0.1)
	VIM:SendMouseButtonEvent(x, y, 0, true, game, 0)
	task.wait(0.05)
	VIM:SendMouseButtonEvent(x, y, 0, false, game, 0)
end

-- Posições fixas de clique (AFKFish)
local ABRIR_X, ABRIR_Y = 105, 190
local FECHAR_X, FECHAR_Y = 720, 74
local RESTAURANTE_X, RESTAURANTE_Y = 560, 33

task.spawn(function()
	while task.wait(1) do
		if afkFishEnabled then
			-- Executa cliques
			clicar(ABRIR_X, ABRIR_Y)
			task.wait(5)
			clicar(FECHAR_X, FECHAR_Y)
			task.wait(0.5)
			clicar(RESTAURANTE_X, RESTAURANTE_Y)
