			-- Teleporta para o destino salvo (se as funções Auto Evento não estiverem ativas para sobrepor isso no futuro)
			teleportTo(afkFishDestino)
			
			-- Loop de espera baseado no tempo setado em 'afkFishTime' (minutos)
			-- Fazemos um mini loop para conseguir cancelar caso você desligue no meio da espera
			local targetEspera = afkFishTime * 60
			local tempoEsperado = 0
			
			while tempoEsperado < targetEspera and afkFishEnabled do
				task.wait(1)
				tempoEsperado = tempoEsperado + 1
			end
		end
	end
end)

