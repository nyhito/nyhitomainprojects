local function applySettingsAfkTime(box)
	local raw = box.Text:match("%d+")
	if raw then
		afkFishTime = math.clamp(tonumber(raw), 1, 60)
		showNotice("Tempo do AFKFish alterado para " .. afkFishTime .. "m.")
	else
		showNotice("Tempo inválido. Mín: 1, Max: 60.")
	end
	box.Text = tostring(afkFishTime) .. "m"
	saveUserPreferences()
end

local function applySettingsAfkPos(box)
	local x, y, z = box.Text:match("([^,]+),([^,]+),([^,]+)")
	if x and y and z then
		afkFishPositionStr = string.format("%d, %d, %d", tonumber(x), tonumber(y), tonumber(z))
		afkFishDestino = CFrame.new(tonumber(x), tonumber(y), tonumber(z))
		showNotice("Posição do AFKFish atualizada: " .. afkFishPositionStr)
	else
		showNotice("Coordenadas inválidas. Use X, Y, Z.")
	end
	box.Text = afkFishPositionStr
	saveUserPreferences()
end

